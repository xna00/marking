{
  "name": "marking",
  "version": "1.0.0",
  "description": "",
  "main": "background.js",
  "type": "module",
  "scripts": {
    "build": "rm dist/**/*.{js,css} ; NODE_ENV=production node ./scripts/vite.build.ts && cd dist/extension && zip -r ../doc/extension.zip . && cd ../.. && node ./scripts/setUpdateUrl.ts && node ./scripts/generate-start-bat.ts",
    "build:dev": "NODE_ENV=development node ./scripts/vite.build.ts",
    "watch": "npm-watch",
    "cp": "./scripts/copyfiles.sh",
    "add-hash": "scripts/add-hash.ts",
    "rename-to-mjs": "scripts/rename-js-to-mjs.ts",
    "build-lib": "scripts/esbuild.ts",
    "generate-bat": "node scripts/generate-start-bat.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "watch": {
    "build": {
      "patterns": [
        "extension",
        "doc"
      ],
      "extensions": "js,ts,tsx,css,html,png,json",
      "quiet": false
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "server",
    "api",
    "extension"
  ],
  "devDependencies": {
    "esbuild": "^0.27.2",
    "npm-watch": "^0.13.0",
    "typescript": "^5.9.3"
  }
}
